            "value": "",
            "type": "query"
          },
          {
            "name": "time",
            "value": "",
            "type": "query",
            "description": "Time filter (for example `2024-01`, `from 2024-01 to 2024-12`)."
          },
          {
            "name": "I_COMMODITY",
            "value": "",
            "type": "query",
            "description": "HS commodity code filter."
          },
          {
            "name": "key",
            "value": "",
            "type": "query"
          }
        ]
      },
