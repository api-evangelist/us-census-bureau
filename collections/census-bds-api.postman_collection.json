              "value": "<string>",
              "description": "(Required) Variables to retrieve (for example `YEAR,FAGE,FIRMS,ESTABS,NET_JOB_CREATION`)."
            },
            {
              "disabled": false,
              "key": "for",
              "value": "<string>",
              "description": "Geography clause (for example `us:*` or `state:06`)."
            },
            {
              "disabled": false,
              "key": "time",
              "value": "<string>",
              "description": "Time filter (for example `2022`, `from 2018 to 2022`)."
            },
